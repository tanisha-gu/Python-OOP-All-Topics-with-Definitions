# Multiple Inheritance allows a class to inherit from more than one parent class at the same time, combining features from all parents.

class Car:
    def __init__(self, brand, model):
        self.brand = brand
        self.model = model

    def fuel_type(self):
        return "Petrol or Diesel"

class Electric:
    def charge(self):
        return "Charging with electricity "

# HybridCar inherits from BOTH Car and Electric
class HybridCar(Car, Electric):
    def __init__(self, brand, model, battery_size):
        super().__init__(brand, model)
        self.battery_size = battery_size

    def fuel_type(self):                   # Here we see Override
        return "Petrol + Electric (Hybrid)"

hybrid = HybridCar("Toyota", "Prius", 50)

print(hybrid.brand)           # From Car       → Toyota
print(hybrid.fuel_type())     # Own override   → Petrol + Electric (Hybrid)
print(hybrid.charge())        # From Electric  → Charging with electricity 
print(isinstance(hybrid, Car))      # True
print(isinstance(hybrid, Electric)) # True
